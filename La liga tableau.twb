      <aliases enabled='yes' />
      <column datatype='integer' name='[Assists]' role='measure' type='quantitative' />
      <column caption='Goals Scored min 1' datatype='boolean' name='[Calculation_1538280340185088]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Goals scored] &gt;= [Parameters].[Goals scored Parameter]' />
      </column>
      <column caption='Goals per 90' datatype='real' name='[Calculation_1538280394469377]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Goals scored] / [Minutes played]) * 90' />
      </column>
      <column caption='t20 players' datatype='integer' name='[Calculation_1538280395280386]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_DENSE(SUM([Goals scored]) / SUM([Minutes played]) * 90, &apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Total Contributions' datatype='integer' name='[Calculation_1538280475910153]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Goals scored]+[Assists]' />
      </column>
      <column caption='contribution %' datatype='real' name='[Calculation_1538280477687818]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Goals scored] + [Assists]) / TOTAL(SUM([Goals scored] + [Assists]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Defensive Stats' datatype='integer' name='[Calculation_1538280485101579]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Interceptions]+[Clearances]+[Tackles]+[Fouls committed]' />
      </column>
